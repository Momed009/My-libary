{
  "expo": {
    "name": "Kütüphanem",
    "slug": "kutuphanem",
    "owner": "momed009",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kutuphanem",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.kiler.kutuphanem",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Barkod taramak için kameraya izin verin."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Kitap teslim tarihi hatırlatmaları eklemek için takvime izin verin."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Kitap kapak fotoğrafı seçmek için galeriye izin verin.",
          "colors": {
            "cropToolbarColor": "#0A84FF"
          },
          "dark": {
            "colors": {
              "cropToolbarColor": "#1C1C1E"
            }
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "targetSdkVersion": 34
          }
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f3432d0a-1fd1-4063-9c44-2a6a84814ee4"
      }
    }
  }
}
